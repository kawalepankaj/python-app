# Container Registry Configuration
REGISTRY=docker.io
IMAGE_REPOSITORY=kawalepankaj/python-app

# Build Information (set by Jenkins)
BUILD_NUMBER=123
GIT_SHA=abc1234

# Computed Image Tag (BUILD_NUMBER-GIT_SHA)
IMAGE_TAG=docker.io/kawalepankaj/python-app:123-abc1234
IMAGE_TAG_LATEST=docker.io/kawalepankaj/python-app:latest

# Kubernetes Configuration
KUBE_NAMESPACE=production
